<odoo noupdate="1">
    <record id="ir_cron_ti_product_duplicate_scan" model="ir.cron">
        <field name="name">PIS: Duplicate Review Scan</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">model.search([('ti_category_id', '!=', False)], limit=200)._cron_ti_duplicate_scan()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
</odoo>

