<odoo>
    <record id="module_category_ti_product_intelligence" model="ir.module.category">
        <field name="name">T&amp;I Product Intelligence</field>
        <field name="sequence">30</field>
    </record>

    <record id="group_ti_product_user" model="res.groups">
        <field name="name">PIS User</field>
        <field name="category_id" ref="module_category_ti_product_intelligence"/>
    </record>

    <record id="group_ti_product_steward" model="res.groups">
        <field name="name">Product Steward</field>
        <field name="category_id" ref="module_category_ti_product_intelligence"/>
        <field name="implied_ids" eval="[(4, ref('group_ti_product_user'))]"/>
    </record>

    <record id="group_ti_price_cost" model="res.groups">
        <field name="name">Cost Price Visibility</field>
        <field name="category_id" ref="module_category_ti_product_intelligence"/>
        <field name="implied_ids" eval="[(4, ref('group_ti_product_user'))]"/>
    </record>

    <record id="group_ti_price_sale" model="res.groups">
        <field name="name">Sale Price Visibility</field>
        <field name="category_id" ref="module_category_ti_product_intelligence"/>
        <field name="implied_ids" eval="[(4, ref('group_ti_product_user'))]"/>
    </record>

    <record id="group_ti_sales_user" model="res.groups">
        <field name="name">Sales PIS User</field>
        <field name="category_id" ref="module_category_ti_product_intelligence"/>
        <field name="implied_ids" eval="[(4, ref('group_ti_price_sale')), (4, ref('group_ti_price_cost'))]"/>
    </record>

    <record id="group_ti_purchase_user" model="res.groups">
        <field name="name">Purchase PIS User</field>
        <field name="category_id" ref="module_category_ti_product_intelligence"/>
        <field name="implied_ids" eval="[(4, ref('group_ti_price_cost'))]"/>
    </record>

    <record id="group_ti_inventory_user" model="res.groups">
        <field name="name">Inventory PIS User</field>
        <field name="category_id" ref="module_category_ti_product_intelligence"/>
        <field name="implied_ids" eval="[(4, ref('group_ti_price_cost'))]"/>
    </record>

    <record id="group_ti_manufacturing_user" model="res.groups">
        <field name="name">Manufacturing PIS User</field>
        <field name="category_id" ref="module_category_ti_product_intelligence"/>
        <field name="implied_ids" eval="[(4, ref('group_ti_product_user'))]"/>
    </record>

    <record id="group_ti_product_manager" model="res.groups">
        <field name="name">Director / PIS Manager</field>
        <field name="category_id" ref="module_category_ti_product_intelligence"/>
        <field name="implied_ids" eval="[
            (4, ref('group_ti_product_steward')),
            (4, ref('group_ti_price_cost')),
            (4, ref('group_ti_price_sale')),
            (4, ref('base.group_system'))
        ]"/>
    </record>

    <record id="rule_ti_duplicate_log_user_read" model="ir.rule">
        <field name="name">PIS duplicate logs readable by PIS users</field>
        <field name="model_id" ref="model_ti_product_duplicate_log"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ti_product_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="rule_ti_cost_history_cost_groups" model="ir.rule">
        <field name="name">PIS cost history restricted to cost groups</field>
        <field name="model_id" ref="model_product_cost_history"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ti_price_cost')), (4, ref('group_ti_product_manager'))]"/>
    </record>

    <record id="rule_ti_sale_history_sales_groups" model="ir.rule">
        <field name="name">PIS sale price history restricted to sales groups</field>
        <field name="model_id" ref="model_product_sale_price_history"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ti_price_sale')), (4, ref('group_ti_product_manager'))]"/>
    </record>
</odoo>
