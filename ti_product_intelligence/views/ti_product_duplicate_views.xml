<odoo>
    <record id="view_ti_product_duplicate_log_tree" model="ir.ui.view">
        <field name="name">ti.product.duplicate.log.tree</field>
        <field name="model">ti.product.duplicate.log</field>
        <field name="arch" type="xml">
            <tree decoration-danger="state == 'blocked'" decoration-warning="state == 'review'">
                <field name="create_date"/>
                <field name="product_tmpl_id"/>
                <field name="duplicate_product_tmpl_id"/>
                <field name="category_id"/>
                <field name="score"/>
                <field name="state"/>
                <field name="override_user_id"/>
            </tree>
        </field>
    </record>

    <record id="view_ti_product_duplicate_log_form" model="ir.ui.view">
        <field name="name">ti.product.duplicate.log.form</field>
        <field name="model">ti.product.duplicate.log</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_approve_override" type="object" string="Approve Override" class="oe_highlight" states="blocked,review,new" groups="ti_product_intelligence.group_ti_product_steward,ti_product_intelligence.group_ti_product_manager"/>
                    <button name="action_dismiss" type="object" string="Dismiss" states="blocked,review,new" groups="ti_product_intelligence.group_ti_product_steward,ti_product_intelligence.group_ti_product_manager"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="product_tmpl_id"/>
                            <field name="duplicate_product_tmpl_id"/>
                            <field name="category_id"/>
                            <field name="score"/>
                        </group>
                        <group>
                            <field name="override_user_id"/>
                            <field name="override_date"/>
                        </group>
                    </group>
                    <field name="reason"/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_ti_product_duplicate_log" model="ir.actions.act_window">
        <field name="name">Duplicate Review</field>
        <field name="res_model">ti.product.duplicate.log</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_open': 1}</field>
    </record>
</odoo>

