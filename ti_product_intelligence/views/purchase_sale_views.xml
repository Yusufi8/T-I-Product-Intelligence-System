<odoo>
    <record id="purchase_order_form_pis_button" model="ir.ui.view">
        <field name="name">purchase.order.form.pis.button</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']" position="before">
                <button name="%(action_ti_product_creation_wizard)d" type="action" string="Create Governed Product" class="btn-primary" context="{'default_name': '', 'source_model': 'purchase.order'}" groups="ti_product_intelligence.group_ti_product_user"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_form_pis_button" model="ir.ui.view">
        <field name="name">sale.order.form.pis.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']" position="before">
                <button name="%(action_ti_product_creation_wizard)d" type="action" string="Create Governed Product" class="btn-primary" context="{'default_name': '', 'source_model': 'sale.order'}" groups="ti_product_intelligence.group_ti_product_user"/>
            </xpath>
        </field>
    </record>
</odoo>
