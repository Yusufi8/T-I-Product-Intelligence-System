<odoo>
    <record id="purchase_order_form_pis_button" model="ir.ui.view">
        <field name="name">purchase.order.form.pis.button</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//control/create[1]" position="attributes">
                <attribute name="context">{'pis_open_product_wizard': True, 'pis_parent_model': 'purchase.order'}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="after">
                <button name="action_open_pis_product_wizard" type="object" icon="fa-plus-circle" title="Create Governed Product" groups="ti_product_intelligence.group_ti_product_user"/>
                <field name="ti_info_uid" optional="hide" readonly="1"/>
                <field name="ti_info_specs" optional="hide" readonly="1"/>
                <field name="ti_info_vendor" optional="hide" readonly="1"/>
                <field name="ti_info_stock" optional="hide" readonly="1"/>
                <field name="ti_info_lead_time" optional="hide" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//form//field[@name='product_id']" position="after">
                <button name="action_open_pis_product_wizard" type="object" icon="fa-plus-circle" string="Create Governed Product" groups="ti_product_intelligence.group_ti_product_user"/>
                <div class="alert alert-info mt-2" attrs="{'invisible': [('product_id', '=', False)]}">
                    <strong><field name="ti_info_uid"/></strong>
                    <span class="ms-2"><field name="ti_info_specs"/></span>
                    <span class="ms-2">Vendor: <field name="ti_info_vendor"/></span>
                    <span class="ms-2">Stock: <field name="ti_info_stock"/></span>
                    <span class="ms-2" groups="ti_product_intelligence.group_ti_price_cost,ti_product_intelligence.group_ti_product_manager">Cost: <field name="ti_info_cost"/></span>
                    <span class="ms-2" groups="ti_product_intelligence.group_ti_price_sale,ti_product_intelligence.group_ti_product_manager">Margin: <field name="ti_info_margin"/>%</span>
                    <span class="ms-2">Lead: <field name="ti_info_lead_time"/> days</span>
                    <span class="ms-2">State: <field name="ti_info_gov_state"/></span>
                </div>
            </xpath>
            <xpath expr="//field[@name='order_line']" position="before">
                <button name="action_open_pis_product_line_wizard" type="object" string="Add Governed Product" class="btn-primary" groups="ti_product_intelligence.group_ti_product_user"/>
            </xpath>
        </field>
    </record>

    <record id="sale_order_form_pis_button" model="ir.ui.view">
        <field name="name">sale.order.form.pis.button</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//control/create[1]" position="attributes">
                <attribute name="context">{'pis_open_product_wizard': True, 'pis_parent_model': 'sale.order'}</attribute>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="after">
                <button name="action_open_pis_product_wizard" type="object" icon="fa-plus-circle" title="Create Governed Product" groups="ti_product_intelligence.group_ti_product_user"/>
                <field name="ti_info_uid" optional="hide" readonly="1"/>
                <field name="ti_info_specs" optional="hide" readonly="1"/>
                <field name="ti_info_vendor" optional="hide" readonly="1"/>
                <field name="ti_info_stock" optional="hide" readonly="1"/>
                <field name="ti_info_lead_time" optional="hide" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//form//field[@name='product_id']" position="after">
                <button name="action_open_pis_product_wizard" type="object" icon="fa-plus-circle" string="Create Governed Product" groups="ti_product_intelligence.group_ti_product_user"/>
                <div class="alert alert-info mt-2" attrs="{'invisible': [('product_id', '=', False)]}">
                    <strong><field name="ti_info_uid"/></strong>
                    <span class="ms-2"><field name="ti_info_specs"/></span>
                    <span class="ms-2">Vendor: <field name="ti_info_vendor"/></span>
                    <span class="ms-2">Stock: <field name="ti_info_stock"/></span>
                    <span class="ms-2" groups="ti_product_intelligence.group_ti_price_cost,ti_product_intelligence.group_ti_product_manager">Cost: <field name="ti_info_cost"/></span>
                    <span class="ms-2" groups="ti_product_intelligence.group_ti_price_sale,ti_product_intelligence.group_ti_product_manager">Margin: <field name="ti_info_margin"/>%</span>
                    <span class="ms-2">Lead: <field name="ti_info_lead_time"/> days</span>
                    <span class="ms-2">State: <field name="ti_info_gov_state"/></span>
                </div>
            </xpath>
            <xpath expr="//field[@name='order_line']" position="before">
                <button name="action_open_pis_product_line_wizard" type="object" string="Add Governed Product" class="btn-primary" groups="ti_product_intelligence.group_ti_product_user"/>
            </xpath>
        </field>
    </record>
</odoo>
