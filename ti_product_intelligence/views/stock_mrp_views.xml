<odoo>
    <record id="stock_picking_form_pis_button" model="ir.ui.view">
        <field name="name">stock.picking.form.pis.button</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_pis_product_wizard" type="object" string="Create Governed Product" class="btn-secondary" groups="ti_product_intelligence.group_ti_product_user"/>
            </xpath>
            <xpath expr="//field[@name='move_ids_without_package']//field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='move_ids_without_package']//field[@name='product_id']" position="after">
                <button name="action_open_pis_product_wizard" type="object" icon="fa-plus-circle" title="Create Governed Product" groups="ti_product_intelligence.group_ti_product_user"/>
                <field name="ti_uid" optional="hide" readonly="1"/>
                <field name="ti_category_id" optional="hide" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="mrp_production_form_pis_button" model="ir.ui.view">
        <field name="name">mrp.production.form.pis.button</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_pis_product_wizard" type="object" string="Create Governed Product" class="btn-secondary" groups="ti_product_intelligence.group_ti_product_user"/>
            </xpath>
            <xpath expr="//field[@name='move_raw_ids']//field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='move_raw_ids']//field[@name='product_id']" position="after">
                <button name="action_open_pis_product_wizard" type="object" icon="fa-plus-circle" title="Create Governed Product" groups="ti_product_intelligence.group_ti_product_user"/>
                <field name="ti_uid" optional="hide" readonly="1"/>
                <field name="ti_category_id" optional="hide" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="mrp_bom_form_pis_button" model="ir.ui.view">
        <field name="name">mrp.bom.form.pis.button</field>
        <field name="model">mrp.bom</field>
        <field name="inherit_id" ref="mrp.mrp_bom_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='bom_line_ids']//field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='bom_line_ids']//field[@name='product_id']" position="after">
                <button name="action_open_pis_product_wizard" type="object" icon="fa-plus-circle" title="Create Governed Product" groups="ti_product_intelligence.group_ti_product_user"/>
                <field name="ti_uid" optional="hide" readonly="1"/>
                <field name="ti_governance_state" optional="hide" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="stock_quant_tree_pis_button" model="ir.ui.view">
        <field name="name">stock.quant.tree.pis.button</field>
        <field name="model">stock.quant</field>
        <field name="inherit_id" ref="stock.view_stock_quant_tree_editable"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='product_id']" position="attributes">
                <attribute name="options">{'no_create': True, 'no_create_edit': True, 'no_quick_create': True}</attribute>
            </xpath>
            <xpath expr="//field[@name='product_id']" position="after">
                <button name="action_open_pis_product_wizard" type="object" icon="fa-plus-circle" title="Create Governed Product" groups="ti_product_intelligence.group_ti_product_user"/>
            </xpath>
        </field>
    </record>
</odoo>
