<odoo>
    <record id="view_ti_product_template_pis_pivot" model="ir.ui.view">
        <field name="name">product.template.pis.pivot</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <pivot string="PIS Product Governance">
                <field name="ti_category_id" type="row"/>
                <field name="ti_governance_state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_ti_product_duplicate_graph" model="ir.ui.view">
        <field name="name">ti.product.duplicate.log.graph</field>
        <field name="model">ti.product.duplicate.log</field>
        <field name="arch" type="xml">
            <graph string="Duplicate Risk" type="bar">
                <field name="category_id"/>
                <field name="score" type="measure"/>
                <field name="state"/>
            </graph>
        </field>
    </record>

    <record id="action_ti_product_governance_dashboard" model="ir.actions.act_window">
        <field name="name">Governance Dashboard</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">pivot,graph,tree</field>
        <field name="domain">[('ti_category_id', '!=', False)]</field>
    </record>
</odoo>

