<odoo>
    <record id="view_ti_product_uid_rule_tree" model="ir.ui.view">
        <field name="name">ti.product.uid.rule.tree</field>
        <field name="model">ti.product.uid.rule</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="template"/>
                <field name="sequence_id"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_ti_product_uid_rule_form" model="ir.ui.view">
        <field name="name">ti.product.uid.rule.form</field>
        <field name="model">ti.product.uid.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <field name="category_id"/>
                        <field name="template"/>
                        <field name="specs_separator"/>
                        <field name="sequence_id"/>
                        <field name="sequence_padding"/>
                        <field name="active"/>
                    </group>
                    <p class="text-muted">Available tokens: {type}, {category}, {specs}, {brand}, {vendor}, {seq}</p>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ti_product_uid_rule" model="ir.actions.act_window">
        <field name="name">UID Rules</field>
        <field name="res_model">ti.product.uid.rule</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
