<odoo>
    <record id="view_ti_duplicate_report_graph" model="ir.ui.view">
        <field name="name">ti.product.duplicate.log.report.graph</field>
        <field name="model">ti.product.duplicate.log</field>
        <field name="arch" type="xml">
            <graph string="Duplicate Count by Category" type="bar">
                <field name="category_id"/>
            </graph>
        </field>
    </record>

    <record id="action_ti_duplicate_report" model="ir.actions.act_window">
        <field name="name">Duplicate Product Count by Category</field>
        <field name="res_model">ti.product.duplicate.log</field>
        <field name="view_mode">graph,tree</field>
        <field name="domain">[('state','in',['new','review','blocked'])]</field>
    </record>

    <record id="view_product_slow_move_report_tree" model="ir.ui.view">
        <field name="name">product.slow.move.report.tree</field>
        <field name="model">product.slow.move.report</field>
        <field name="arch" type="xml">
            <tree>
                <field name="product_tmpl_id"/>
                <field name="ti_category_id"/>
                <field name="qty_available"/>
                <field name="last_move_date"/>
            </tree>
        </field>
    </record>

    <record id="view_product_slow_move_report_graph" model="ir.ui.view">
        <field name="name">product.slow.move.report.graph</field>
        <field name="model">product.slow.move.report</field>
        <field name="arch" type="xml">
            <graph string="Slow-Moving Inventory" type="bar">
                <field name="ti_category_id"/>
                <field name="slow_count" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_product_slow_move_report" model="ir.actions.act_window">
        <field name="name">Slow-Moving Inventory</field>
        <field name="res_model">product.slow.move.report</field>
        <field name="view_mode">graph,tree</field>
    </record>

    <record id="view_ti_missing_spec_report_pivot" model="ir.ui.view">
        <field name="name">ti.missing.spec.report.pivot</field>
        <field name="model">ti.missing.spec.report</field>
        <field name="arch" type="xml">
            <pivot string="Missing Mandatory Specs">
                <field name="category_id" type="row"/>
                <field name="attribute_id" type="col"/>
                <field name="missing_count" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_ti_missing_spec_report_tree" model="ir.ui.view">
        <field name="name">ti.missing.spec.report.tree</field>
        <field name="model">ti.missing.spec.report</field>
        <field name="arch" type="xml">
            <tree>
                <field name="product_tmpl_id"/>
                <field name="category_id"/>
                <field name="attribute_id"/>
                <field name="missing_count"/>
            </tree>
        </field>
    </record>

    <record id="action_ti_missing_spec_report" model="ir.actions.act_window">
        <field name="name">Missing Mandatory Specs</field>
        <field name="res_model">ti.missing.spec.report</field>
        <field name="view_mode">pivot,tree</field>
    </record>

    <record id="view_ti_bom_usage_report_tree" model="ir.ui.view">
        <field name="name">ti.bom.usage.report.tree</field>
        <field name="model">ti.bom.usage.report</field>
        <field name="arch" type="xml">
            <tree>
                <field name="product_tmpl_id"/>
                <field name="ti_category_id"/>
                <field name="bom_id"/>
                <field name="usage_count"/>
                <field name="consumed_qty"/>
            </tree>
        </field>
    </record>

    <record id="view_ti_bom_usage_report_graph" model="ir.ui.view">
        <field name="name">ti.bom.usage.report.graph</field>
        <field name="model">ti.bom.usage.report</field>
        <field name="arch" type="xml">
            <graph string="BOM Usage" type="bar">
                <field name="ti_category_id"/>
                <field name="usage_count" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_ti_bom_usage_report" model="ir.actions.act_window">
        <field name="name">BOM Usage</field>
        <field name="res_model">ti.bom.usage.report</field>
        <field name="view_mode">graph,tree</field>
    </record>

    <record id="view_product_cost_history_pivot_vendor" model="ir.ui.view">
        <field name="name">product.cost.history.vendor.pivot</field>
        <field name="model">product.cost.history</field>
        <field name="arch" type="xml">
            <pivot string="Vendor Product Price Mapping">
                <field name="ti_category_id" type="row"/>
                <field name="partner_id" type="col"/>
                <field name="new_price" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_ti_vendor_product_price_mapping" model="ir.actions.act_window">
        <field name="name">Vendor Product Price Mapping</field>
        <field name="res_model">product.cost.history</field>
        <field name="view_mode">pivot,tree,graph</field>
    </record>

    <record id="view_product_sale_margin_graph_category" model="ir.ui.view">
        <field name="name">product.sale.price.history.margin.graph</field>
        <field name="model">product.sale.price.history</field>
        <field name="arch" type="xml">
            <graph string="Sales Margin by PIS Category" type="bar">
                <field name="ti_category_id"/>
                <field name="margin_percent" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_ti_sales_margin_analysis" model="ir.actions.act_window">
        <field name="name">Sales Margin Analysis</field>
        <field name="res_model">product.sale.price.history</field>
        <field name="view_mode">graph,pivot,tree</field>
    </record>
</odoo>
