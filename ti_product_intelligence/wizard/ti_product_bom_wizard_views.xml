<odoo>
    <record id="view_ti_product_bom_wizard_form" model="ir.ui.view">
        <field name="name">ti.product.bom.wizard.form</field>
        <field name="model">ti.product.bom.wizard</field>
        <field name="arch" type="xml">
            <form string="Create BOM">
                <sheet>
                    <group>
                        <field name="product_tmpl_id"/>
                        <field name="bom_type"/>
                    </group>
                    <field name="component_line_ids">
                        <tree editable="bottom">
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="uom_id"/>
                            <field name="operation_id"/>
                        </tree>
                    </field>
                </sheet>
                <footer>
                    <button name="action_create_bom" type="object" string="Create BOM" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ti_product_bom_wizard" model="ir.actions.act_window">
        <field name="name">Create BOM</field>
        <field name="res_model">ti.product.bom.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

