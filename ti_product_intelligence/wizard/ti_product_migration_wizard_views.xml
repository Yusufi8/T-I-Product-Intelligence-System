<odoo>
    <record id="view_ti_product_migration_wizard_form" model="ir.ui.view">
        <field name="name">ti.product.migration.wizard.form</field>
        <field name="model">ti.product.migration.wizard</field>
        <field name="arch" type="xml">
            <form string="Prepare Existing Products for PIS">
                <sheet>
                    <group>
                        <field name="category_id"/>
                        <field name="batch_limit"/>
                        <field name="preserve_default_code"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_prepare_products" type="object" string="Prepare Batch" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ti_product_migration_wizard" model="ir.actions.act_window">
        <field name="name">Migration Cleanup</field>
        <field name="res_model">ti.product.migration.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>

